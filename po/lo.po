#: plparse/totem-disc.c:276 plparse/totem-disc.c:289 plparse/totem-disc.c:532
#, c-format
msgid "Failed to mount %s."
msgstr "ລົ້ມເຫຼວໃນການເຊື່ອມຕໍ່ %s."

#: plparse/totem-disc.c:418
#, c-format
msgid "No media in drive for device “%s”."
msgstr "ບໍ່ມີມີເດຍໃນໄດຣຟ໌ສຳລັບອຸປະກອນ “%s”."

#: plparse/totem-disc.c:475
#, c-format
msgid "Please check that a disc is present in the drive."
msgstr "ກະລຸນາກວດສອບວ່າມີແຜ່ນຢູ່ໃນໄດຣຟ໌."

#: plparse/totem-disc.c:946
msgid "Audio CD"
msgstr "ຊີດີສຽງ"

#: plparse/totem-disc.c:948
msgid "Video CD"
msgstr "ຊີດີວິດີໂອ"

#: plparse/totem-disc.c:950
msgid "DVD"
msgstr "ດີວີດີ"

#: plparse/totem-disc.c:952
msgid "Digital Television"
msgstr "ໂທລະພາບດິຈິຕອນ"

#: plparse/totem-disc.c:954
msgid "Blu-ray"
msgstr "ບລູເຣ"
